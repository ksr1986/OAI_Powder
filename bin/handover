#!/bin/bash
UPDATE_ATTENS_SCRIPT=/local/repository/bin/update-attens
DST_RU=$1
ATTEN_STEP=5
START_ATTEN_SRC=15
START_ATTEN_DST=60

usage() {
    cat <<EOF
usage:
    handover -h
        show this help message
    handover <dst_ru>
        handover UE to <dst_ru> using 5 dB atten steps
        <dst_ru> must be bru1 (only one RU in this deployment)
EOF
}

if [ -z $DST_RU ]; then
  usage; exit 1
fi

if [ $DST_RU != "bru1" ]; then
  echo "invalid dst_ru: only bru1 is available"; usage; exit 1
fi

SRC_RU="bru1"

handover() {
  echo "handing over UE to $DST_RU..."
  for atten in $(seq $START_ATTEN_SRC $ATTEN_STEP $START_ATTEN_DST); do
    $UPDATE_ATTENS_SCRIPT $SRC_RU $atten
    $UPDATE_ATTENS_SCRIPT $DST_RU $((START_ATTEN_SRC + START_ATTEN_DST - atten))
  done
}

handover
